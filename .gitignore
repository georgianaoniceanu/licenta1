# Ignore everything by default
*
*.*

# But keep backend and frontend directories
!backend/
!frontend/

# Keep git files
!.gitignore
!.git/
!.github/

# Restore directories so their contents can be tracked
!*/

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
.venv/
backend/.venv/
backend/venv/
frontend/node_modules/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Environment variables
.env
.env.*
*.env
.tmp

# Node
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log
coverage/
