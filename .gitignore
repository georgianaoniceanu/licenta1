# Ignore loose files at the repo ROOT only (scratch scripts, PDFs, exports).
# Everything that matters lives under backend/ and frontend/, which are tracked
# in full below. Their own .gitignore files handle secrets and caches.
/*
!/backend/
!/frontend/
!/.gitignore
!/.github/

# Belt-and-suspenders: never track secrets or caches even inside tracked dirs.
**/__pycache__/
**/*.py[cod]
**/*$py.class
**/.venv/
**/venv/
**/env/
**/node_modules/
**/.expo/
**/dist/
**/web-build/

# Secrets / credentials
**/.env
**/.env.*
**/*.env
**/firebase_key.json
**/serviceAccountKey.json
**/*serviceAccount*.json

# OS / IDE
.DS_Store
Thumbs.db
**/.vscode/
**/.idea/
*.swp
